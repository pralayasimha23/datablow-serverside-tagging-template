___SANDBOXED_JS_FOR_SERVER___

const getAllEventData = require('getAllEventData');
const sendHttpRequest = require('sendHttpRequest');
const getRequestHeader = require('getRequestHeader');
const getCookieValues = require('getCookieValues');
const JSON = require('JSON');
const generateRandom = require('generateRandom');

const eventData = getAllEventData();

const trackingUrl = data.trackingUrl; // e.g. "https://track.yourdomain.com"
const tenantId = data.tenantId;       // CapiSite.id / tenant identifier

const clientIp = getRequestHeader('x-forwarded-for') || getRequestHeader('forwarded') || '';
const userAgent = getRequestHeader('user-agent') || '';

// Construct payload
const payload = {
  event_name: eventData.event_name || 'PageView',
  event_id: eventData.event_id || (eventData.client_id ? eventData.client_id + '_' + generateRandom(100000, 999999) : '' + generateRandom(1000000000, 9999999999)),
  user_data: eventData.user_data || {},
  custom_data: eventData.custom_data || {},
  page_location: eventData.page_location,
  page_referrer: eventData.page_referrer,
  client_id: eventData.client_id,
  tenant_id: tenantId
};

// Add standard cookies if available
const fbp = getCookieValues('_fbp')[0];
if (fbp) payload.fbp = fbp;
const fbc = getCookieValues('_fbc')[0];
if (fbc) payload.fbc = fbc;

const postBody = JSON.stringify(payload);
const postUrl = trackingUrl + '/sc/collect';

sendHttpRequest(postUrl, (statusCode, headers, body) => {
  if (statusCode >= 200 && statusCode < 300) {
    data.gtmOnSuccess();
  } else {
    data.gtmOnFailure();
  }
}, {method: 'POST', headers: {'Content-Type': 'application/json'}}, postBody);


